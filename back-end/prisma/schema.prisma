generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────

enum Role {
  ADMIN
  REVIEWER
  LECTURER
  STUDENT
}

enum WorkStatus {
  DRAFT
  SUBMITTED
  OUTLINE_REVIEW
  PROPOSAL_REVIEW
  IN_PROGRESS
  REVIEW
  REVISION
  ACCEPTED
  REJECTED
  ARCHIVED
}

enum WorkLevel {
  UNIVERSITY
  MINISTRY
  STATE
}

enum WorkType {
  JOURNAL_ARTICLE
  CONFERENCE_PAPER
  RESEARCH_PROJECT
  PATENT
  TEXTBOOK
  THESIS
}

enum FileCategory {
  MANUSCRIPT
  PROPOSAL
  REPORT
  REVIEW_FORM
  CERTIFICATE
  ATTACHMENT
}

enum NotificationType {
  WORKFLOW
  COMMITTEE
  DEADLINE
  SYSTEM
}

enum PublicationStatus {
  DRAFT
  CONFIRMED
  PUBLISHED
}

enum TransactionType {
  ALLOCATION
  DISBURSEMENT
  REFUND
}

enum TransactionStatus {
  PENDING
  APPROVED
  REJECTED
  COMPLETED
}

enum RewardType {
  CASH
  CERTIFICATE
  LETTER
}

enum RewardStatus {
  PENDING
  APPROVED
  AWARDED
}

// ─── User ────────────────────────────────────────────────

model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  name         String?
  password     String
  role         Role     @default(STUDENT)
  isActive     Boolean  @default(true)
  department   String?
  specialization String?
  phone        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  scientificWorks  ScientificWork[]
  committeeMembers CommitteeMember[]
  reviews          Review[]
  notifications    Notification[]
  uploadedFiles    FileUpload[]
  publications     Publication[]
  libraryItems     LibraryDocument[]
  rewards          Reward[]
  approvedTransactions BudgetTransaction[] @relation("TransactionApprover")
  approvedRewards  Reward[]              @relation("RewardApprover")
  researchHours    ResearchHours[]
  preferences      UserPreference[]
  createdTemplates DocumentTemplate[] @relation("TemplateCreator")
  renderedDocs     RenderedDocument[] @relation("DocCreator")
}

// ─── Scientific Work (Core Entity) ──────────────────────

model ScientificWork {
  id          Int        @id @default(autoincrement())
  title       String
  authors     String
  abstract    String?
  content     String?
  keywords    String[]
  type        WorkType   @default(RESEARCH_PROJECT)
  level       WorkLevel  @default(UNIVERSITY)
  status      WorkStatus @default(DRAFT)

  // AI analysis results
  aiScore         Int?
  aiRank          String?
  aiSummary       String?
  aiKeywords      String[]
  similarityScore Float?

  // Budget & metrics
  budget        Float?
  researchHours Float?
  journalName   String?
  issn          String?
  doi           String?
  publishedDate DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId    Int?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  files          FileUpload[]
  workflowSteps  WorkflowStep[]
  committees     Committee[]
  reviews        Review[]
  notifications  Notification[]
  publications   Publication[]
  libraryItems   LibraryDocument[]
  budgetTransactions BudgetTransaction[]
  rewards        Reward[]
}

// ─── Workflow ────────────────────────────────────────────

model WorkflowStep {
  id          Int        @id @default(autoincrement())
  name        String
  description String?
  order       Int
  status      WorkStatus
  comment     String?
  completedAt DateTime?
  dueDate     DateTime?
  createdAt   DateTime   @default(now())

  workId Int
  work   ScientificWork @relation(fields: [workId], references: [id], onDelete: Cascade)
}

// ─── Committee ───────────────────────────────────────────

model Committee {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  meetingDate DateTime?
  location    String?
  finalScore  Float?
  conclusion  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workId  Int
  work    ScientificWork @relation(fields: [workId], references: [id], onDelete: Cascade)

  members CommitteeMember[]
  reviews Review[]
}

model CommitteeMember {
  id        Int    @id @default(autoincrement())
  role      String // "chair", "secretary", "reviewer", "member"
  createdAt DateTime @default(now())

  committeeId Int
  committee   Committee @relation(fields: [committeeId], references: [id], onDelete: Cascade)

  userId Int
  user   User @relation(fields: [userId], references: [id])

  @@unique([committeeId, userId])
}

// ─── Review / Scoring ────────────────────────────────────

model Review {
  id             Int    @id @default(autoincrement())
  innovationScore    Float?   // 0-40
  feasibilityScore   Float?   // 0-30
  impactScore        Float?   // 0-30
  totalScore         Float?
  comment            String?
  recommendation     String?  // "accept", "revise", "reject"
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  workId      Int
  work        ScientificWork @relation(fields: [workId], references: [id], onDelete: Cascade)

  reviewerId  Int
  reviewer    User @relation(fields: [reviewerId], references: [id])

  committeeId Int?
  committee   Committee? @relation(fields: [committeeId], references: [id])
}

// ─── File Upload ─────────────────────────────────────────

model FileUpload {
  id           Int          @id @default(autoincrement())
  filename     String
  originalName String
  mimeType     String
  size         Int
  path         String
  category     FileCategory @default(MANUSCRIPT)

  // AI extraction results
  extractedText   String?
  extractedTitle  String?
  extractedAuthors String?
  extractedAbstract String?
  extractedKeywords String[]
  ocrConfidence   Float?

  createdAt DateTime @default(now())

  workId Int?
  work   ScientificWork? @relation(fields: [workId], references: [id], onDelete: SetNull)

  uploaderId Int
  uploader   User @relation(fields: [uploaderId], references: [id])

  publications Publication[]
}

// ─── Notification ────────────────────────────────────────

model Notification {
  id      Int              @id @default(autoincrement())
  title   String
  message String
  type    NotificationType @default(SYSTEM)
  isRead  Boolean          @default(false)
  link    String?
  createdAt DateTime       @default(now())

  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  workId Int?
  work   ScientificWork? @relation(fields: [workId], references: [id], onDelete: SetNull)
}

// ─── Publication (Công bố khoa học) ─────────────────────

model Publication {
  id            Int               @id @default(autoincrement())
  title         String
  authors       String
  abstract      String?
  journalName   String?
  conferenceName String?
  publishedDate DateTime?
  doi           String?
  issn          String?
  keywords      String[]
  confidence    Float?
  status        PublicationStatus  @default(DRAFT)

  fileId        Int?
  file          FileUpload?       @relation(fields: [fileId], references: [id])

  userId        Int
  user          User              @relation(fields: [userId], references: [id])

  workId        Int?
  work          ScientificWork?   @relation(fields: [workId], references: [id], onDelete: SetNull)

  libraryItem   LibraryDocument?

  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
}

// ─── Library Document (Kho lưu trữ số Thông minh) ──────

model LibraryDocument {
  id            Int        @id @default(autoincrement())
  title         String
  authors       String
  abstract      String?
  keywords      String[]
  tags          String[]
  category      String?
  type          WorkType
  level         WorkLevel?
  aiScore       Float?
  viewCount     Int        @default(0)
  downloadCount Int        @default(0)

  publicationId Int?       @unique
  publication   Publication? @relation(fields: [publicationId], references: [id], onDelete: SetNull)

  workId        Int?
  work          ScientificWork? @relation(fields: [workId], references: [id], onDelete: SetNull)

  userId        Int
  user          User       @relation(fields: [userId], references: [id])

  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
}

// ─── Budget (Ngân sách) ─────────────────────────────────

model Budget {
  id              Int      @id @default(autoincrement())
  name            String
  totalAmount     Float
  allocatedAmount Float    @default(0)
  disbursedAmount Float    @default(0)
  fiscalYear      Int
  department      String?

  transactions    BudgetTransaction[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ─── Budget Transaction (Giao dịch ngân sách) ──────────

model BudgetTransaction {
  id          Int               @id @default(autoincrement())
  amount      Float
  type        TransactionType
  description String?
  status      TransactionStatus @default(PENDING)

  budgetId    Int
  budget      Budget            @relation(fields: [budgetId], references: [id], onDelete: Cascade)

  workId      Int?
  work        ScientificWork?   @relation(fields: [workId], references: [id], onDelete: SetNull)

  approvedById Int?
  approvedBy   User?            @relation("TransactionApprover", fields: [approvedById], references: [id])

  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
}

// ─── Reward (Khen thưởng) ───────────────────────────────

model Reward {
  id          Int          @id @default(autoincrement())
  title       String
  description String?
  type        RewardType
  amount      Float?
  period      String?
  status      RewardStatus @default(PENDING)

  userId      Int
  user        User         @relation(fields: [userId], references: [id])

  workId      Int?
  work        ScientificWork? @relation(fields: [workId], references: [id], onDelete: SetNull)

  approvedById Int?
  approvedBy   User?        @relation("RewardApprover", fields: [approvedById], references: [id])

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

// ─── Journal Ranking (Danh mục tạp chí) ────────────────

model JournalRanking {
  id          Int      @id @default(autoincrement())
  name        String
  issn        String?
  publisher   String?
  category    String?  // "Scopus", "ISI/WoS", "HĐGSNN", "Trong nước"
  quartile    String?  // "Q1", "Q2", "Q3", "Q4", "ESCI"
  impactFactor Float?
  points      Float    @default(0) // Điểm quy đổi theo HĐGSNN
  hIndex      Int?
  country     String?
  url         String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([name])
  @@index([issn])
}

// ─── Research Hours (Giờ chuẩn NCKH) ───────────────────

model ResearchHours {
  id          Int      @id @default(autoincrement())
  userId      Int
  user        User     @relation(fields: [userId], references: [id])

  academicYear String  // "2024-2025"

  // Điểm từ các nguồn
  publicationPoints  Float @default(0)  // Từ bài báo
  projectPoints      Float @default(0)  // Từ đề tài NCKH
  reviewPoints       Float @default(0)  // Từ phản biện
  supervisionPoints  Float @default(0)  // Từ hướng dẫn SV
  otherPoints        Float @default(0)  // Khác

  totalPoints        Float @default(0)
  requiredPoints     Float @default(50) // Định mức giờ chuẩn
  status             String @default("CALCULATING") // CALCULATING, SUBMITTED, APPROVED

  note               String?
  approvedById       Int?
  approvedAt         DateTime?

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@unique([userId, academicYear])
}

// ─── System Config (Cấu hình hệ thống) ────────────────

model SystemConfig {
  id          Int      @id @default(autoincrement())
  key         String   @unique
  value       String
  type        String   @default("string")  // string, number, boolean, json
  group       String   @default("general") // general, research, notification, display
  label       String                        // Tên hiển thị
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── User Preference (Tùy chỉnh cá nhân) ──────────────

model UserPreference {
  id     Int    @id @default(autoincrement())
  userId Int
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  key    String
  value  String

  @@unique([userId, key])
}

// ─── Document Template (Mẫu tài liệu động) ────────────

enum TemplateCategory {
  DECISION        // Quyết định
  REPORT          // Báo cáo
  CONTRACT        // Hợp đồng
  CERTIFICATE     // Giấy khen / Bằng khen
  MINUTES         // Biên bản
  EVALUATION      // Phiếu đánh giá
  OTHER
}

model DocumentTemplate {
  id          Int              @id @default(autoincrement())
  name        String
  code        String           @unique    // VD: "QD-NGHIEM-THU", "BB-HOI-DONG"
  category    TemplateCategory @default(OTHER)
  description String?
  content     String           // HTML với {{key}} placeholders
  headerHtml  String?          // Header chung (logo, tên trường)
  footerHtml  String?          // Footer chung (chữ ký, ngày tháng)
  variables   String[]         // Danh sách keys sử dụng: ["ten_de_tai", "tac_gia"]
  isActive    Boolean          @default(true)
  version     Int              @default(1)

  createdById Int
  createdBy   User             @relation("TemplateCreator", fields: [createdById], references: [id])

  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  renderedDocs RenderedDocument[]
}

model TemplateVariable {
  id          Int      @id @default(autoincrement())
  key         String   @unique       // "ten_de_tai"
  label       String                 // "Tên đề tài"
  description String?                // "Lấy từ bảng ScientificWork"
  source      String                 // "ScientificWork.title" - mapping đến DB field
  group       String   @default("work") // work, user, committee, finance, system
  dataType    String   @default("string") // string, number, date, list
  format      String?                // VD: "DD/MM/YYYY" cho date, "#,##0" cho number
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
}

// Tài liệu đã render (lưu lại để tra cứu)
model RenderedDocument {
  id          Int      @id @default(autoincrement())
  templateId  Int
  template    DocumentTemplate @relation(fields: [templateId], references: [id])
  name        String           // Tên file xuất: "QD-001-Nghiem-thu-DT-2024"
  htmlContent String           // HTML đã render (đã thay {{key}} = giá trị thật)
  sourceData  Json?            // JSON snapshot dữ liệu lúc render

  // Liên kết tài liệu gốc
  workId      Int?
  committeeId Int?
  userId      Int?

  createdById Int
  createdBy   User   @relation("DocCreator", fields: [createdById], references: [id])

  createdAt   DateTime @default(now())
}
